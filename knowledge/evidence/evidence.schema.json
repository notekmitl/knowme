{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://knowme/knowledge/evidence/evidence.schema.json",
  "title": "Thai Astrology — Evidence Records",
  "description": "Schema for citable evidence sources consumed by KnowledgeEvidenceEngine. Research records reference these by id (evidenceIds). One evidence record may back many research records. Knowledge layer only — no engine or matrix dependency.",
  "type": "object",
  "required": ["schemaVersion", "domain", "records"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "string" },
    "domain": { "type": "string", "const": "knowledge_evidence" },
    "description": { "type": "string" },
    "records": {
      "type": "array",
      "items": { "$ref": "#/definitions/evidenceRecord" }
    }
  },
  "definitions": {
    "evidenceRecord": {
      "type": "object",
      "required": ["id", "sourceType", "school", "author", "book", "language", "reviewStatus"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable unique id, e.g. \"EV-0001\"." },
        "sourceType": { "type": "string", "description": "book | manuscript | article | website | oral | ..." },
        "school": { "type": "string" },
        "author": { "type": "string" },
        "book": { "type": "string" },
        "edition": { "type": ["string", "null"] },
        "publisher": { "type": ["string", "null"] },
        "year": { "type": ["integer", "null"] },
        "page": { "type": ["string", "null"] },
        "language": { "type": "string" },
        "quote": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] },
        "license": { "type": ["string", "null"] },
        "reviewStatus": {
          "type": "string",
          "enum": ["draft", "reviewed", "verified", "disputed", "deprecated"]
        },
        "reviewer": { "type": ["string", "null"] },
        "createdAt": { "type": ["string", "null"], "description": "ISO-8601" },
        "updatedAt": { "type": ["string", "null"], "description": "ISO-8601" },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
